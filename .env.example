PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/tobeque_ecommerce?appName=Tobeque

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=24h

# SMTP Email Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME="Tobeque Admin"
SMTP_FROM_EMAIL=noreply@tobeque.com
