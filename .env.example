PORT=5000
NODE_ENV=development

# Database Configuration (Leave blank/missing to use SQLite fallback in development!)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tobeque_ecommerce
DB_USER=root
DB_PASS=

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=24h

# SMTP Email Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME="Tobeque Admin"
SMTP_FROM_EMAIL=noreply@tobeque.com
